# ---------- Server ----------
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development

# ---------- Paths (relative to ai-service/) ----------
DATA_DIR=./data
MODELS_DIR=./data/models
UPLOADS_DIR=./data/uploads
CACHE_DIR=./data/cache

# ---------- Qdrant ----------
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

# ---------- Embeddings ----------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_SEQ_LENGTH=512

# ---------- Chunking ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# ---------- Document processing ----------
DOC_MAX_FILE_BYTES=26214400
DOC_MAX_FILES_PER_REQUEST=10
DOC_ALLOWED_EXTS=.pdf,.docx,.txt

# ---------- Groq LLM ----------
# Use GROQ_API_KEYS for failover across multiple keys (comma-separated).
# When the first key hits a rate-limit or auth error, the next key is tried.
# GROQ_API_KEY is supported for backward compatibility (treated as a 1-key pool).
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT_SECONDS=30

# ---------- Website Crawler ----------
CRAWLER_MAX_PAGES=8
CRAWLER_TIMEOUT_SECONDS=20
CRAWLER_USER_AGENT=AIBridge-Crawler/0.1 (+https://aibridge.local)

# ---------- Chatbot ----------
CHAT_TOP_K=6
CHAT_SCORE_THRESHOLD=0.30
CHAT_MAX_CONTEXT_CHARS=6000